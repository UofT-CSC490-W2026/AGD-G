# Database (local Postgres via docker-compose)
AGDG_DB_HOST=localhost
AGDG_DB_PORT=5432
AGDG_DB_USER=agdg
AGDG_DB_PASSWORD=agdg
AGDG_DB_NAME=agdg
AGDG_DB_SSLMODE=disable

# S3-compatible storage (MinIO via docker-compose)
AGDG_S3_ENDPOINT=http://localhost:9000
AGDG_S3_BUCKET=agdg-local
AGDG_S3_REGION=us-east-1

# MinIO credentials (used by boto3 via standard AWS env vars)
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# Hugging Face token (required for gated models / dataset downloads)
# HF_TOKEN=hf_...
